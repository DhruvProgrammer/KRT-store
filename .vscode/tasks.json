{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🔄 Auto-push (every 10s)",
      "type": "shell",
      "command": "node",
      "args": ["scripts/auto-push.cjs"],
      "detail": "Checks for changes every 10s, auto-commits and pushes to origin/main",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "icon": {
        "id": "sync",
        "color": "terminal.ansiGreen"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "close": false
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "📤 Manual push",
      "type": "shell",
      "command": "git add . && git commit -m 'manual update' && git push",
      "group": "build",
      "presentation": {
        "reveal": "always"
      },
      "problemMatcher": []
    }
  ]
}
