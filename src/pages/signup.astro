---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer";
import AuthForm from "../components/AuthForm";

const title = "Create account — KRT store";
const description = "Create your account in one step. We'll email you a verification link.";
---

<BaseLayout title={title} description={description}>
  <Navigation />
  <main id="main" class="container mx-auto px-4 pt-6 pb-20 sm:px-6 lg:px-8">
    <nav class="mb-6 flex flex-wrap items-center gap-2 text-xs font-bold uppercase tracking-[0.18em] text-ink-muted" aria-label="Breadcrumb">
      <a href="/" class="transition hover:text-ink">Home</a>
      <span aria-hidden="true">/</span>
      <span class="text-ink">Create account</span>
    </nav>

    <div class="mx-auto max-w-xl">
      <AuthForm client:load mode="signup" />
    </div>
  </main>
  <Footer client:load />
</BaseLayout>
