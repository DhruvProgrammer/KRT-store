---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navigation from "../../components/Navigation.astro";
import Footer from "../../components/Footer";
import ExtraDetail from "../../components/ExtraDetail";
import { extras, type ExtraItem } from "../../data/extras";

export const getStaticPaths = () =>
  extras.map((p) => ({ params: { slug: p.slug }, props: { item: p } }));

interface Props {
  item: ExtraItem;
}

const { item } = Astro.props as Props;
const title = `${item.name} — KRT Extras`;
const description = item.description;
---

<BaseLayout title={title} description={description}>
  <Navigation />
  <main id="main" class="container mx-auto px-4 pt-6 pb-20 sm:px-6 lg:px-8">
    <nav class="mb-6 flex flex-wrap items-center gap-2 text-xs font-bold uppercase tracking-[0.18em] text-ink-muted" aria-label="Breadcrumb">
      <a href="/" class="transition hover:text-ink">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/extras" class="transition hover:text-ink">Extras</a>
      <span aria-hidden="true">/</span>
      <span class="text-ink">{item.name}</span>
    </nav>

    <ExtraDetail client:load item={item} />
  </main>
  <Footer client:load />
</BaseLayout>
