---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer";
import CheckoutForm from "../components/CheckoutForm";

const title = "Checkout — KRT store";
const description = "Complete your order and receive instant download links for your digital goods.";
---

<BaseLayout title={title} description={description}>
  <Navigation />
  <main id="main">
    <nav class="container mx-auto flex flex-wrap items-center gap-2 px-4 pt-6 text-xs font-bold uppercase tracking-[0.18em] text-ink-muted sm:px-6 lg:px-8" aria-label="Breadcrumb">
      <a href="/" class="transition hover:text-ink">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/cart" class="transition hover:text-ink">Cart</a>
      <span aria-hidden="true">/</span>
      <span class="text-ink">Checkout</span>
    </nav>
    <CheckoutForm client:load />
  </main>
  <Footer client:load />
</BaseLayout>
