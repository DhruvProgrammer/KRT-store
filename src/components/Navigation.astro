---
import SearchModal, { type SearchProduct, type SearchExtra } from "./SearchModal";
import { products } from "../data/products";
import { extras } from "../data/extras";

const links = [
  { href: "/", label: "Home" },
  { href: "/store", label: "Store" },
  { href: "/extras", label: "Extras" },
  { href: "/#contact", label: "Contact" }
];

const announcement = "Free updates for life · 30-day refund";

const searchProducts: SearchProduct[] = products.map((p) => ({
  slug: p.slug,
  name: p.name,
  description: p.description,
  tag: p.tag,
  category: p.category
}));

const searchExtras: SearchExtra[] = extras.map((e) => ({
  slug: e.slug,
  name: e.name,
  description: e.description,
  tag: e.tag,
  category: e.category
}));
---

<header class="sticky top-0 z-40 border-b border-line bg-bg-soft/90 backdrop-blur-xl" data-navigation>
  <div class="border-b border-line/60">
    <div class="container mx-auto flex h-9 items-center justify-between gap-2 px-4 text-[11px] font-semibold uppercase tracking-[0.18em] text-ink-muted sm:px-6 lg:px-8">
      <p class="flex items-center gap-2 truncate">
        <span class="inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-accent shadow-[0_0_10px_rgba(0,162,255,0.7)]"></span>
        <span class="truncate">{announcement}</span>
      </p>
      <div class="hidden items-center gap-4 sm:flex">
        <a href="/store" class="transition hover:text-ink">Browse store</a>
        <span aria-hidden="true" class="opacity-30">·</span>
        <a href="mailto:hello@krt.example" class="transition hover:text-ink">hello@krt.example</a>
      </div>
      <a href="/login" class="sm:hidden transition hover:text-ink">Sign in</a>
    </div>
  </div>

  <div class="container mx-auto flex h-16 items-center justify-between gap-4 px-4 sm:px-6 lg:px-8">
    <a href="/" class="group flex items-center gap-2" aria-label="KRT store home">
      <span class="grid h-9 w-9 place-items-center rounded-xl bg-accent font-black text-ink-inverse shadow-[0_0_18px_rgba(0,162,255,0.45)] transition group-hover:scale-105">
        K
      </span>
      <span class="text-base font-black tracking-[-0.04em] text-ink truncate">KRT store</span>
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Primary navigation">
      {links.map((link) => (
        <a
          href={link.href}
          class="rounded-full px-4 py-2 text-sm font-semibold text-ink-muted transition hover:bg-slate-800/40 hover:text-ink"
        >
          {link.label}
        </a>
      ))}
    </nav>

    {/* DESKTOP header buttons */}
    <div class="hidden items-center gap-2 md:flex">
      <a
        href="/login"
        class="inline-flex h-10 items-center gap-2 rounded-full border border-line bg-surface-ink px-4 text-xs font-bold text-ink-muted transition hover:border-accent/40 hover:bg-surface-bright hover:text-ink"
      >
        <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" class="h-4 w-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
          <circle cx="12" cy="7" r="4" />
        </svg>
        <span>Sign in</span>
      </a>

      <button
        type="button"
        data-open-search
        aria-label="Open search"
        title="Search (⌘K)"
        class="hidden h-10 items-center gap-2 rounded-full border border-line bg-surface-ink px-4 text-xs font-bold text-ink-muted transition hover:border-accent/40 hover:bg-surface-bright lg:inline-flex"
      >
        <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" class="h-5 w-5">
          <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2" />
          <path d="m20 20-3.5-3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
        <span>Search</span>
        <span aria-hidden="true" class="hidden rounded border border-line bg-surface px-1.5 py-0.5 text-[10px] font-black uppercase tracking-[0.18em] text-ink-muted sm:inline-block">
          ⌘K
        </span>
      </button>

      <div class="relative">
        <button
          type="button"
          data-open-cart
          aria-label="Open cart"
          class="relative inline-flex h-10 w-10 items-center justify-center rounded-full border border-line bg-surface-ink text-ink transition hover:border-accent/40 hover:bg-surface-bright"
        >
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" class="h-5 w-5">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4zM3 6h18M16 10a4 4 0 0 1-8 0" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span
            data-cart-count
            class="pointer-events-none absolute -right-1 -top-1 hidden h-5 min-w-[1.25rem] place-items-center rounded-full bg-accent px-1 text-[10px] font-black text-white shadow-[0_0_12px_rgba(0,162,255,0.5)]"
          >
            <span data-cart-count-text>0</span>
          </span>
        </button>
      </div>

      <a
        href="/store"
        class="hidden items-center gap-2 rounded-full bg-accent px-4 py-2 text-xs font-black uppercase tracking-[0.18em] text-white shadow-[0_0_22px_rgba(0,162,255,0.35)] transition hover:bg-accent-bright hover:shadow-[0_0_30px_rgba(0,162,255,0.55)] lg:inline-flex"
      >
        Shop now
      </a>
    </div>

    {/* MOBILE header buttons */}
    <div class="flex items-center gap-2 md:hidden">
      <button
        type="button"
        data-open-search
        aria-label="Open search"
        title="Search (⌘K)"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-line bg-surface-ink text-ink transition hover:border-accent/40 hover:bg-surface-bright"
      >
        <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" class="h-5 w-5">
          <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2" />
          <path d="m20 20-3.5-3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </button>

      <div class="relative">
        <button
          type="button"
          data-open-cart
          aria-label="Open cart"
          class="relative inline-flex h-10 w-10 items-center justify-center rounded-full border border-line bg-surface-ink text-ink transition hover:border-accent/40 hover:bg-surface-bright"
        >
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" class="h-5 w-5">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4zM3 6h18M16 10a4 4 0 0 1-8 0" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span
            data-cart-count
            class="pointer-events-none absolute -right-1 -top-1 hidden h-5 min-w-[1.25rem] place-items-center rounded-full bg-accent px-1 text-[10px] font-black text-white shadow-[0_0_12px_rgba(0,162,255,0.5)]"
          >
            <span data-cart-count-text>0</span>
          </span>
        </button>
      </div>

      <button
        type="button"
        data-mobile-trigger
        aria-label="Open menu"
        aria-expanded="false"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-line bg-surface-ink text-ink transition hover:bg-surface-bright"
      >
        <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" class="h-5 w-5">
          <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>

  <div class="hidden border-t border-line bg-bg-soft md:hidden" data-mobile-panel>
    <nav class="container mx-auto flex flex-col gap-1 px-4 py-4 sm:px-6" aria-label="Mobile primary">
      <p class="px-2 text-[11px] font-black uppercase tracking-[0.2em] text-ink-muted">Browse</p>
      {links.map((link) => (
        <a
          href={link.href}
          class="rounded-2xl px-4 py-3 text-sm font-bold text-ink-muted transition hover:bg-slate-800/40 hover:text-ink"
        >
          {link.label}
        </a>
      ))}

      <p class="mt-4 px-2 text-[11px] font-black uppercase tracking-[0.2em] text-ink-muted">Account</p>
      <a href="/login" class="rounded-2xl px-4 py-3 text-sm font-bold text-ink-muted transition hover:bg-slate-800/40 hover:text-ink">Sign in</a>
      <a href="/signup" class="rounded-2xl px-4 py-3 text-sm font-bold text-ink-muted transition hover:bg-slate-800/40 hover:text-ink">Create account</a>
      <a href="/profile" class="rounded-2xl px-4 py-3 text-sm font-bold text-ink-muted transition hover:bg-slate-800/40 hover:text-ink">Profile</a>
      <a href="/settings" class="rounded-2xl px-4 py-3 text-sm font-bold text-ink-muted transition hover:bg-slate-800/40 hover:text-ink">Settings</a>
      <a href="/cart" class="rounded-2xl px-4 py-3 text-sm font-bold text-ink-muted transition hover:bg-slate-800/40 hover:text-ink">Cart</a>

      <a href="/store" class="mt-4 rounded-2xl bg-accent px-4 py-3 text-center text-sm font-black text-white shadow-[0_0_22px_rgba(0,162,255,0.35)] transition hover:bg-accent-bright">
        Browse store
      </a>
    </nav>

    <div class="border-t border-line/60">
      <div class="container mx-auto flex flex-wrap items-center justify-center gap-x-5 gap-y-2 px-4 py-4 text-[11px] font-bold uppercase tracking-[0.18em] text-ink-muted sm:px-6">
        <a href="/privacy" class="transition hover:text-ink">Privacy</a>
        <span aria-hidden="true" class="opacity-30">·</span>
        <a href="/terms" class="transition hover:text-ink">Terms</a>
        <span aria-hidden="true" class="opacity-30">·</span>
        <a href="/#contact" class="transition hover:text-ink">Contact</a>
      </div>
    </div>
  </div>
</header>

{/* On-demand React singleton — only the search modal needs React (for combobox state). */}
<SearchModal client:load products={searchProducts} extras={searchExtras} />

<script is:inline>
  (function () {
    // ============ Cart badge sync ============
    const STORAGE_KEY = "dg-cart";
    const BAD = /<|>|javascript:|data:|@import|url\(|expression\(/i;
    const MAX_QTY = 99;

    const validateGradient = (v) => {
      if (typeof v !== "string") return false;
      const t = v.trim();
      if (t.length === 0 || t.length > 500) return false;
      return !BAD.test(t);
    };
    const safeNumber = (v, min, max) => {
      const n = Number(v);
      return Number.isFinite(n) && n >= min && n <= max;
    };
    const validateItem = (raw) => {
      if (!raw || typeof raw !== "object") return false;
      if (typeof raw.slug !== "string" || raw.slug.length === 0 || raw.slug.length > 120) return false;
      if (typeof raw.name !== "string" || raw.name.length === 0 || raw.name.length > 200) return false;
      if (!safeNumber(raw.price, 0, 100000)) return false;
      if (!safeNumber(raw.quantity, 1, MAX_QTY)) return false;
      return validateGradient(raw.gradient);
    };

    const readItems = () => {
      try {
        const raw = window.localStorage.getItem(STORAGE_KEY);
        if (!raw) return [];
        const items = JSON.parse(raw);
        if (!Array.isArray(items)) return [];
        const valid = items.filter(validateItem);
        return valid;
      } catch (e) {
        return [];
      }
    };

    const readCount = () =>
      readItems().reduce((sum, item) => sum + Number(item.quantity || 0), 0);

    const updateBadges = () => {
      const count = readCount();
      document.querySelectorAll("[data-cart-count]").forEach((b) => {
        const text = b.querySelector("[data-cart-count-text]");
        if (text) text.textContent = String(count);
        b.classList.toggle("hidden", count === 0);
        b.classList.toggle("flex", count > 0);
        b.classList.toggle("grid", count > 0);
      });
    };

    updateBadges();
    window.addEventListener("cart:update", updateBadges);
    window.addEventListener("storage", (event) => {
      if (event.key === STORAGE_KEY) updateBadges();
    });

    // ============ Cart popover (vanilla — no React hydration race) ============
    const formatPrice = (cents) =>
      new Intl.NumberFormat("en-US", { style: "currency", currency: "USD" }).format(cents);

    // Build an HTML-safe escape function using only comment-safe characters.
    const escapeAmp = String.fromCharCode(38);
    const escapeLt = String.fromCharCode(60);
    const escapeGt = String.fromCharCode(62);
    const escapeQuot = String.fromCharCode(34);
    const escapeApos = String.fromCharCode(39);
    const escapeHtml = (value) => {
      const v = String(value);
      return v
        .replace(/&/g, escapeAmp + "#38;")
        .replace(/</g, escapeLt + "#60;")
        .replace(/>/g, escapeGt + "#62;")
        .replace(/"/g, escapeQuot + "#34;")
        .replace(/'/g, escapeApos + "#39;");
    };

    function escapeCssUrl(value) {
      // SEC-DEFENSE-IN-DEPTH: validated cart items already reject these chars.
      // This is a second-pass shim that also drops backtick and quotes.
      return String(value)
        .replace(/`/g, "")
        .replace(/"/g, "")
        .replace(/'/g, "")
        .replace(/\$\(/g, "")
        .slice(0, 500);
    }

    function renderCartItem(item) {
      const trimmed = (item.name || "").toString().slice(0, 80);
      const lineTotal = formatPrice(Number(item.price) * Number(item.quantity));
      const gradient = escapeCssUrl(item.gradient || "#1f2430");
      return (
        '<li class="flex gap-3">' +
          '<div class="h-12 w-12 shrink-0 rounded-lg border border-line" style="background:' + gradient + '"></div>' +
          '<div class="min-w-0 flex-1">' +
            '<p class="truncate text-sm font-bold text-ink">' + escapeHtml(trimmed) + "</p>" +
            '<p class="mt-0.5 text-[11px] uppercase tracking-[0.18em] text-ink-muted">Qty ' +
            escapeHtml(String(item.quantity)) +
            "</p>" +
            '<div class="mt-1 flex items-center justify-between text-xs text-ink-muted">' +
            "<span>" + lineTotal + "</span>" +
            '<button type="button" data-remove="' + escapeHtml(String(item.slug)) + '" class="font-black uppercase tracking-[0.18em] text-ink-muted transition hover:text-red-400">Remove</button>' +
            "</div>" +
          "</div>" +
        "</li>"
      );
    }

    function renderPopover() {
      const items = readItems();
      const count = items.reduce((sum, i) => sum + Number(i.quantity || 0), 0);
      const total = items.reduce((sum, i) => sum + Number(i.price) * Number(i.quantity), 0);

      const header =
        '<header class="flex items-center justify-between border-b border-line px-4 py-3">' +
        '<p class="text-xs font-black uppercase tracking-[0.18em] text-ink-muted">Cart</p>' +
        '<p class="text-xs font-black uppercase tracking-[0.18em] text-ink">' +
        count + " " + (count === 1 ? "item" : "items") +
        "</p>" +
        "</header>";

      let body;
      if (items.length === 0) {
        body =
          '<div class="px-4 py-6 text-center">' +
            '<p class="text-base font-black text-ink">Your cart is empty.</p>' +
            '<p class="mt-1 text-xs text-ink-muted">Add a product to see it here.</p>' +
            '<a href="/store" data-close-cart class="mt-4 inline-flex items-center justify-center rounded-full bg-accent px-4 py-2 text-xs font-black uppercase tracking-[0.18em] text-white shadow-[0_0_22px_rgba(0,162,255,0.35)] transition hover:bg-accent-bright">Browse store</a>' +
          "</div>";
      } else {
        const list = items
          .slice(0, 4)
          .map(renderCartItem)
          .join("");
        const more =
          items.length > 4
            ? '<li><a href="/cart" data-close-cart class="block text-center text-xs font-black uppercase tracking-[0.18em] text-ink-muted transition hover:text-accent">+' +
              (items.length - 4) + " more — view cart</a></li>"
            : "";
        const footer =
          '<footer class="border-t border-line bg-bg-soft/80 px-4 py-3">' +
            '<div class="flex justify-between text-sm"><span class="font-bold text-ink">Subtotal</span><span class="font-black text-accent drop-shadow-[0_0_8px_rgba(0,162,255,0.25)]">' +
            formatPrice(total) +
            "</span></div>" +
            '<div class="mt-3 grid grid-cols-2 gap-2">' +
              '<a href="/cart" data-close-cart class="rounded-full border border-line px-3 py-2 text-center text-xs font-black uppercase tracking-[0.18em] text-ink transition hover:border-accent/40 hover:text-accent">View cart</a>' +
              '<a href="/checkout" data-close-cart class="rounded-full bg-accent px-3 py-2 text-center text-xs font-black uppercase tracking-[0.18em] text-white shadow-[0_0_22px_rgba(0,162,255,0.35)] transition hover:bg-accent-bright">Checkout</a>' +
            "</div>" +
            '<p class="mt-2 text-[10px] leading-tight text-ink-muted">Instant digital download · secure checkout</p>' +
          "</footer>";
        body =
          '<ul class="max-h-72 space-y-3 overflow-auto px-4 py-3">' + list + more + "</ul>" + footer;
      }

      return header + body;
    }

    let popoverEl = null;
    function ensurePopover() {
      if (popoverEl) return popoverEl;
      const root = document.createElement("div");
      root.id = "krt-cart-popover";
      root.setAttribute("role", "dialog");
      root.setAttribute("aria-label", "Shopping cart preview");
      root.className =
        "fixed right-2 top-[68px] z-[60] hidden w-[min(22rem,calc(100vw-1rem))] origin-top-right rounded-2xl border border-line bg-bg-soft/95 shadow-[0_18px_44px_rgba(0,0,0,0.55)] backdrop-blur-xl";
      root.hidden = true;
      document.body.appendChild(root);
      popoverEl = root;
      return root;
    }

    function openPopover() {
      const root = ensurePopover();
      root.innerHTML = renderPopover();
      requestAnimationFrame(() => {
        root.hidden = false;
        root.classList.remove("hidden");
        root.classList.add("flex");
        root.classList.add("flex-col");
      });
    }
    function closePopover() {
      const root = popoverEl;
      if (!root) return;
      root.hidden = true;
      root.classList.add("hidden");
      root.classList.remove("flex");
      root.classList.remove("flex-col");
    }

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      if (target.closest("[data-close-cart]") || target.closest('button[data-remove]')) {
        closePopover();
      }
      if (target.closest("button[data-remove]")) {
        const slug = target.getAttribute("data-remove") || "";
        if (!slug) return;
        try {
          const items = readItems();
          const next = items.filter((i) => i.slug !== slug);
          window.localStorage.setItem(STORAGE_KEY, JSON.stringify(next));
          window.dispatchEvent(new Event("cart:update"));
        } catch (e) {
          /* ignore */
        }
        return;
      }
      if (target.closest("[data-open-search]")) {
        const evt = new CustomEvent("krt:open-search");
        window.dispatchEvent(evt);
      }
      if (target.closest("[data-open-cart]")) {
        event.preventDefault();
        event.stopPropagation();
        openPopover();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closePopover();
      }
      if ((event.key === "k" || event.key === "K") && (event.metaKey || event.ctrlKey)) {
        event.preventDefault();
        const evt = new CustomEvent("krt:open-search");
        window.dispatchEvent(evt);
      }
    });

    document.addEventListener("mousedown", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      const root = popoverEl;
      if (!root || root.hidden) return;
      if (root.contains(target)) return;
      if (target.closest("[data-open-cart]")) return;
      closePopover();
    });

    // ============ Mobile menu toggle ============
    const panel = document.querySelector("[data-mobile-panel]");
    const trigger = document.querySelector("[data-mobile-trigger]");
    if (panel) {
      const setOpen = (open) => {
        panel.classList.toggle("hidden", !open);
        if (trigger) trigger.setAttribute("aria-expanded", String(open));
      };
      window.addEventListener("krt:toggle-menu", () => {
        const isOpen = !panel.classList.contains("hidden");
        setOpen(!isOpen);
      });
      panel.querySelectorAll("a").forEach((anchor) =>
        anchor.addEventListener("click", () => {
          panel.classList.add("hidden");
          if (trigger) trigger.setAttribute("aria-expanded", "false");
        })
      );
      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && !panel.classList.contains("hidden")) {
          setOpen(false);
        }
      });
    }
  })();
</script>
